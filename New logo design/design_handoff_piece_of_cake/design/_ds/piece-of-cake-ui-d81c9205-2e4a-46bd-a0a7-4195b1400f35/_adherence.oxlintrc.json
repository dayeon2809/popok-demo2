{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/general/ArtistCard/**",
              "components/general/ArtistModal/**",
              "components/general/AuthNav/**",
              "components/general/CountUp/**",
              "components/general/EmptyState/**",
              "components/general/ErrorMessage/**",
              "components/general/LoadingSpinner/**",
              "components/general/Logo3D/**",
              "components/general/PerformanceCard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard Variable))/i]",
        "message": "Font not provided by the design system. Available: Pretendard Variable."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ArtistCard": {
        "replaces": []
      },
      "ArtistModal": {
        "replaces": []
      },
      "AuthNav": {
        "replaces": []
      },
      "CountUp": {
        "replaces": []
      },
      "EmptyState": {
        "replaces": []
      },
      "ErrorMessage": {
        "replaces": []
      },
      "LoadingSpinner": {
        "replaces": []
      },
      "Logo3D": {
        "replaces": []
      },
      "PerformanceCard": {
        "replaces": []
      }
    },
    "tokens": [
      "--accent",
      "--accent-dark",
      "--accent-light",
      "--bg",
      "--bg-card",
      "--bg-warm",
      "--border",
      "--border-dark",
      "--ink",
      "--ink-faint",
      "--ink-muted",
      "--navy",
      "--needs-review",
      "--tag-bg",
      "--verified"
    ],
    "tokenKinds": {
      "--bg": "color",
      "--bg-warm": "color",
      "--bg-card": "color",
      "--ink": "color",
      "--ink-muted": "color",
      "--ink-faint": "color",
      "--accent": "color",
      "--accent-dark": "color",
      "--accent-light": "color",
      "--border": "color",
      "--border-dark": "color",
      "--tag-bg": "color",
      "--navy": "color",
      "--verified": "color",
      "--needs-review": "color"
    },
    "fontFamilies": [
      "Pretendard Variable"
    ]
  }
}